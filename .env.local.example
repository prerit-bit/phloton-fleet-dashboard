# Anedya IoT Platform Credentials
NEXT_PUBLIC_ANEDYA_API_KEY=your_anedya_api_key_here

# Node IDs — JSON object mapping unit numbers to Anedya node IDs
# Example: {"node_1":"abc-123","node_2":"def-456","node_3":"ghi-789"}
NEXT_PUBLIC_NODES_ID={}

# Variable Identifiers — JSON object mapping variable keys to their config
# Example: {"variable_1":{"identifier":"battery_soc","name":"Battery SoC"},...}
NEXT_PUBLIC_VARIABLES_IDENTIFIER={}
